{
  "project": {
    "name": "serpentstack-frontend",
    "language": "Python + TypeScript",
    "framework": "FastAPI + React",
    "devCmd": "make dev",
    "testCmd": "make verify",
    "conventions": "Services flush, routes commit. Domain returns, not exceptions. Real Postgres in tests."
  },
  "agents": {
    "log-watcher": {
      "enabled": true,
      "model": "ollama/llama3.2"
    },
    "skill-maintainer": {
      "enabled": true,
      "model": "ollama/llama3.2"
    },
    "test-runner": {
      "enabled": true,
      "model": "ollama/llama3.2"
    }
  }
}
