# ── Core ──────────────────────────────────────────────────────
PROJECT_NAME=ClawStack
ENVIRONMENT=dev
VERSION=0.1.0

# ── Database ──────────────────────────────────────────────────
# Async driver (asyncpg) — used by the application
DATABASE_URL=postgresql+asyncpg://clawstack:clawstack@localhost:5432/clawstack
# Docker Compose Postgres credentials
POSTGRES_USER=clawstack
POSTGRES_PASSWORD=clawstack
POSTGRES_DB=clawstack

# ── Security ──────────────────────────────────────────────────
# IMPORTANT: Change this in staging/prod — the app will refuse to start
# with the default value in non-dev environments
SECRET_KEY=change-me-in-production

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated origins or JSON array
CORS_ORIGINS=["http://localhost:5173"]
# CORS__ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
# CORS__ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]

# ── Auth ──────────────────────────────────────────────────────
AUTH_PROVIDER=custom
# For Clerk/Auth0, also set:
# AUTH__JWKS_URL=https://your-provider/.well-known/jwks.json
# AUTH__ISSUER=https://your-provider/
# AUTH__AUDIENCE=your-audience

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT=100/minute
# For multi-instance production, use Redis:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379

# ── Database Pool (optional) ──────────────────────────────────
# DB__POOL_SIZE=5
# DB__MAX_OVERFLOW=10
# DB__POOL_TIMEOUT=30
# DB__POOL_RECYCLE=1800
# DB__ECHO=false

# ── Sentry (optional) ────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
